# QF_RAEP_Engine environment template
# Copy to one of these runtime locations:
# 1) /data/.env (container/runtime mount)
# 2) src/data/.env (local fallback used by src/main.py)

# -------------------------
# OANDA
# -------------------------
OANDA_ENV=practice
OANDA_API_TOKEN=your_oanda_api_token
OANDA_ACCOUNT_ID=your_oanda_account_id
# Optional: override API host if needed
# OANDA_BASE_URL=https://api-fxpractice.oanda.com/v3

# -------------------------
# PostgreSQL
# -------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# -------------------------
# NATS
# -------------------------
NATS_URL=nats://localhost:4222
NATS_USER=your_nats_user
NATS_PASS=your_nats_password

# -------------------------
# Telegram (optional but recommended)
# -------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID_ALERT=your_alert_chat_id
TELEGRAM_CHAT_ID_INFO=your_info_chat_id

# -------------------------
# Engine behavior
# -------------------------
GET_TICK=false
IS_DEV=true

